# =============================================================
# ContaHub — Template de Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o .env com valores reais.
# =============================================================

# ---------------------------
# Supabase (Produção)
# ---------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------
# Supabase Local (Desenvolvimento)
# ---------------------------
SUPABASE_LOCAL_URL=http://localhost:54321
SUPABASE_LOCAL_ANON_KEY=
SUPABASE_LOCAL_SERVICE_ROLE_KEY=

# ---------------------------
# Autentique (Assinatura Digital)
# ---------------------------
AUTENTIQUE_API_KEY=

# ---------------------------
# Stripe (Billing recorrente — cartão + Pix + boleto, BRL)
# ---------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key: só é necessária se algum dia usarmos Stripe.js no cliente.
# No modelo hosted (Checkout + Customer Portal) o backend basta.
STRIPE_PUBLISHABLE_KEY=

# ---------------------------
# Resend (E-mails Transacionais)
# ---------------------------
RESEND_API_KEY=
# Remetente dos e-mails (domínio verificado no Resend)
EMAIL_FROM="ContaHub <no-reply@contahub.com.br>"

# ---------------------------
# Billing — URLs de retorno
# ---------------------------
# Para onde o Stripe Customer Portal volta após o contador gerenciar a assinatura
PORTAL_RETURN_URL=http://localhost:1420

# ---------------------------
# Admin (Next.js)
# ---------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---------------------------
# Sentry (Monitoramento)
# ---------------------------
SENTRY_DSN=
