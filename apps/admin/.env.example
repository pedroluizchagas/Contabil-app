# Supabase — URL e anon key são públicos e usados tanto no server quanto no
# client. Sempre com prefixo NEXT_PUBLIC_ para evitar divergência.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SEGREDO. Apenas server-side (Server Actions protegidas).
# Nunca prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
